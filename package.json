{
  "name": "terminal-roast",
  "displayName": "Terminal Roast!",
  "description": "VS Code doesn't play any sound when a terminal command fails — this extension changes that! Automatically plays a sound effect when your terminal command returns an error. Choose from a variety of built-in sound effects to make your debugging experience more fun and noticeable.",
  "version": "0.0.1",
  "publisher": "DWcoco08",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DWcoco08/error-sound.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "error-sound.selectSound",
        "title": "Terminal Roast: Select Error Sound"
      },
      {
        "command": "error-sound.toggle",
        "title": "Terminal Roast: Toggle On/Off"
      }
    ],
    "configuration": {
      "title": "Terminal Roast",
      "properties": {
        "terminalRoast.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable error sound"
        },
        "terminalRoast.sound": {
          "type": "string",
          "default": "bruh",
          "enum": ["bruh", "fahhhh", "mixi", "bonk"],
          "enumItemLabels": ["Bruh!", "Fahhhh!", "Mixi!", "Bonk!"],
          "description": "Choose which sound to play on terminal error"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
